---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Kevins persönliches Reise-Logbuch — von Solingen in die Welt.",
  ogImage = "/og-default.png",
} = Astro.props;

const currentPath = Astro.url.pathname;
const canonicalURL = new URL(currentPath, Astro.site);
const ogImageURL   = new URL(ogImage, Astro.site);
const fullTitle    = title === "Home" ? "Trepper Global — Von Solingen in die Welt" : `${title} — Trepper Global`;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content="Trepper Global" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImageURL} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale"      content="de_DE" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImageURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png"     href="/favicon.png" sizes="32x32" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <!-- Leaflet JS synchron geladen damit window.L sofort verfügbar ist -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a href="/" class="nav-logo">
          <span class="logo-dot"></span>
          Trepper Global
        </a>
        <div class="nav-links">
          <a href="/jetzt" class:list={["nav-link nav-link-live", { active: currentPath === "/jetzt" }]}>
            <span class="nav-live-dot"></span>Jetzt
          </a>
          <a href="/logbook" class:list={["nav-link", { active: currentPath.startsWith("/logbook") }]}>Logbuch</a>
          <a href="/orte" class:list={["nav-link", { active: currentPath.startsWith("/orte") }]}>Orte</a>
          <a href="/route" class:list={["nav-link", { active: currentPath === "/route" }]}>Route</a>
          <a href="/about" class:list={["nav-link", { active: currentPath === "/about" }]}>Über mich</a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <span>Kevin Trepper · Unterwegs seit 2026</span>
        <div class="footer-right">
          <a href="/impressum" class="footer-link">Impressum</a>
          <span class="footer-instagram">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            @trepper
          </span>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --coral:        #F97316;
    --coral-light:  #FFF7ED;
    --coral-mid:    #FDBA74;
    --teal:         #0EA5E9;
    --teal-light:   #E0F2FE;
    --yellow:       #EAB308;
    --yellow-light: #FEF9C3;
    --green:        #10B981;
    --green-light:  #D1FAE5;
    --purple:       #8B5CF6;
    --purple-light: #EDE9FE;
    --pink:         #EC4899;
    --pink-light:   #FCE7F3;
    --text:         #0F172A;
    --text-mid:     #475569;
    --text-light:   #94A3B8;
    --border:       #E2E8F0;
    --bg:           #FFFFFF;
    --bg-soft:      #F8FAFC;
    --radius:       16px;
    --radius-sm:    10px;
    --shadow:       0 2px 12px rgba(15,23,42,0.08);
    --shadow-lg:    0 8px 32px rgba(15,23,42,0.14);
  }

  html {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    scroll-behavior: smooth;
  }

  body { min-height: 100vh; display: flex; flex-direction: column; }
  main { flex: 1; }
  img  { max-width: 100%; border-radius: var(--radius-sm); }
  a    { color: inherit; text-decoration: none; }

  /* ── SCROLL ANIMATIONS ──
     Elemente sind IMMER sichtbar. Sobald JS bereit ist,
     wird .js-ready auf <html> gesetzt und dann erst werden
     .reveal-Elemente versteckt und animiert eingeblendet.
     → Kein Risiko, dass Content unsichtbar bleibt.
  */
  .js-ready .reveal {
    opacity: 0;
    transform: translateY(26px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .js-ready .reveal.in-view {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stagger für .reveal-stagger Container */
  .js-ready .reveal-stagger > * {
    opacity: 0;
    transform: translateY(22px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }

  .js-ready .reveal-stagger.in-view > *:nth-child(1) { transition-delay: 0.04s; }
  .js-ready .reveal-stagger.in-view > *:nth-child(2) { transition-delay: 0.12s; }
  .js-ready .reveal-stagger.in-view > *:nth-child(3) { transition-delay: 0.20s; }
  .js-ready .reveal-stagger.in-view > *:nth-child(4) { transition-delay: 0.28s; }
  .js-ready .reveal-stagger.in-view > *:nth-child(5) { transition-delay: 0.36s; }

  .js-ready .reveal-stagger.in-view > * {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<style>
  /* NAV */
  .nav {
    position: sticky;
    top: 0;
    z-index: 200;
    background: rgba(255,255,255,0.94);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 8px;
    letter-spacing: -0.02em;
  }

  .logo-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--coral);
    animation: logopulse 2.2s ease-in-out infinite;
  }

  @keyframes logopulse {
    0%, 100% { transform: scale(1);   opacity: 1; }
    50%       { transform: scale(1.4); opacity: 0.6; }
  }

  .nav-links { display: flex; gap: 0.2rem; align-items: center; }

  .nav-link-live { display: inline-flex; align-items: center; gap: 5px; }
  .nav-live-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--coral);
    flex-shrink: 0;
    animation: livepulse 2s ease-in-out infinite;
  }
  @keyframes livepulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(249,115,22,.5); }
    50%      { box-shadow: 0 0 0 4px rgba(249,115,22,0); }
  }

  .nav-link {
    padding: 0.45rem 1rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-mid);
    transition: all 0.15s;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--coral);
    background: var(--coral-light);
  }

  /* FOOTER */
  .footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem;
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    color: var(--text-light);
  }

  .footer-right {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .footer-link {
    font-size: 0.85rem;
    color: var(--text-light);
    text-decoration: none;
    transition: color .15s;
  }
  .footer-link:hover { color: var(--coral); }

  .footer-instagram {
    display: flex;
    align-items: center;
    gap: 6px;
  }
</style>

<script is:inline>
  // Setzt .js-ready auf <html> und startet dann den Observer.
  // So ist Content ohne JS immer sichtbar.
  (function () {
    document.documentElement.classList.add('js-ready');

    function activate(el) {
      el.classList.add('in-view');
    }

    function initObserver() {
      var observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              activate(entry.target);
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.08, rootMargin: '0px 0px -20px 0px' }
      );

      var els = document.querySelectorAll('.reveal, .reveal-stagger');
      els.forEach(function (el) {
        var rect = el.getBoundingClientRect();
        // Elemente die beim Laden schon sichtbar sind → sofort einblenden
        if (rect.top < window.innerHeight && rect.bottom > 0) {
          setTimeout(function () { activate(el); }, 60);
        } else {
          observer.observe(el);
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initObserver);
    } else {
      initObserver();
    }
  })();
</script>
