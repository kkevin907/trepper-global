---
interface Props {
  variant?: 'section' | 'inline';
}
const { variant = 'section' } = Astro.props;
---

<div class={`nl-wrap nl-wrap--${variant}`} id="newsletter">
  <div class="nl-inner">
    <div class="nl-icon" aria-hidden="true">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
        <polyline points="22,6 12,13 2,6"/>
      </svg>
    </div>

    <div class="nl-text">
      <p class="nl-label">Newsletter</p>
      <h2 class="nl-title">Immer wissen, wann's was Neues gibt.</h2>
      <p class="nl-sub">
        Neue Reiseberichte, Orte, Tipps — direkt in dein Postfach. Kein Spam, nur Updates wenn ich wirklich was zu erzählen hab.
      </p>
    </div>

    <form class="nl-form" id="nl-form" novalidate>
      <div class="nl-field">
        <input
          type="email"
          name="email"
          id="nl-email"
          placeholder="deine@email.de"
          autocomplete="email"
          required
          class="nl-input"
        />
        <button type="submit" class="nl-btn" id="nl-btn">
          <span class="nl-btn-text">Anmelden</span>
          <span class="nl-btn-spinner" aria-hidden="true"></span>
        </button>
      </div>
      <p class="nl-hint">Kostenlos · jederzeit abmeldbar</p>
    </form>

    <div class="nl-success" id="nl-success" aria-live="polite">
      <div class="nl-success-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
      <div>
        <strong>Du bist dabei!</strong>
        <p>Ich meld mich, sobald es was Neues gibt.</p>
      </div>
    </div>

    <div class="nl-error" id="nl-error" aria-live="polite"></div>
  </div>
</div>

<style>
  .nl-wrap {
    background: linear-gradient(135deg, #FFF7ED 0%, #FFFBF5 100%);
    border: 1.5px solid #FDBA74;
    border-radius: 20px;
    padding: 2.25rem 2rem;
  }

  .nl-wrap--section {
    max-width: 680px;
    margin: 0 auto;
  }

  .nl-inner {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .nl-icon {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: var(--coral);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .nl-label {
    font-size: .72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: #C2410C;
    margin-bottom: .25rem;
  }

  .nl-title {
    font-size: clamp(1.25rem, 3vw, 1.6rem);
    font-weight: 800;
    letter-spacing: -.03em;
    color: var(--text);
    line-height: 1.2;
    margin-bottom: .5rem;
  }

  .nl-sub {
    font-size: .92rem;
    color: var(--text-mid);
    line-height: 1.65;
  }

  .nl-form { display: flex; flex-direction: column; gap: .5rem; }

  .nl-field {
    display: flex;
    gap: .5rem;
  }

  .nl-input {
    flex: 1;
    padding: .75rem 1rem;
    border: 1.5px solid #FDBA74;
    border-radius: 100px;
    font-size: .9rem;
    font-family: inherit;
    color: var(--text);
    background: white;
    outline: none;
    transition: border-color .15s, box-shadow .15s;
    min-width: 0;
  }
  .nl-input::placeholder { color: #CBD5E1; }
  .nl-input:focus {
    border-color: var(--coral);
    box-shadow: 0 0 0 3px rgba(249,115,22,.12);
  }

  .nl-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: .5rem;
    padding: .75rem 1.5rem;
    background: var(--coral);
    color: white;
    border: none;
    border-radius: 100px;
    font-size: .9rem;
    font-weight: 700;
    font-family: inherit;
    cursor: pointer;
    transition: background .15s, transform .15s, box-shadow .15s;
    white-space: nowrap;
    min-height: 44px;
  }
  .nl-btn:hover:not(:disabled) {
    background: #EA6A0A;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(249,115,22,.3);
  }
  .nl-btn:disabled { opacity: .7; cursor: not-allowed; transform: none; }

  .nl-btn-spinner {
    display: none;
    width: 14px;
    height: 14px;
    border: 2px solid rgba(255,255,255,.4);
    border-top-color: white;
    border-radius: 50%;
    animation: nl-spin .6s linear infinite;
  }
  .nl-btn.loading .nl-btn-text    { display: none; }
  .nl-btn.loading .nl-btn-spinner { display: block; }

  @keyframes nl-spin { to { transform: rotate(360deg); } }

  .nl-hint {
    font-size: .75rem;
    color: #94A3B8;
    padding-left: .25rem;
  }

  /* SUCCESS */
  .nl-success {
    display: none;
    align-items: center;
    gap: .85rem;
    background: #ECFDF5;
    border: 1.5px solid #6EE7B7;
    border-radius: 12px;
    padding: .9rem 1.1rem;
  }
  .nl-success.visible { display: flex; }
  .nl-success-icon {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #10B981;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .nl-success strong { font-size: .95rem; color: #065F46; display: block; margin-bottom: .1rem; }
  .nl-success p { font-size: .82rem; color: #047857; margin: 0; }

  /* ERROR */
  .nl-error {
    display: none;
    font-size: .82rem;
    color: #DC2626;
    background: #FEF2F2;
    border: 1.5px solid #FCA5A5;
    border-radius: 10px;
    padding: .65rem 1rem;
  }
  .nl-error.visible { display: block; }

  @media (max-width: 500px) {
    .nl-wrap { padding: 1.5rem 1.25rem; border-radius: 16px; }
    .nl-field { flex-direction: column; }
    .nl-btn { width: 100%; }
  }
</style>

<script>
  const form    = document.getElementById('nl-form') as HTMLFormElement | null;
  const input   = document.getElementById('nl-email') as HTMLInputElement | null;
  const btn     = document.getElementById('nl-btn') as HTMLButtonElement | null;
  const success = document.getElementById('nl-success');
  const errorEl = document.getElementById('nl-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!input || !btn || !success || !errorEl) return;

    const email = input.value.trim();
    errorEl.textContent = '';
    errorEl.classList.remove('visible');

    // Client-side validation
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      errorEl.textContent = 'Bitte gib eine gültige E-Mail-Adresse ein.';
      errorEl.classList.add('visible');
      input.focus();
      return;
    }

    btn.disabled = true;
    btn.classList.add('loading');

    try {
      const res  = await fetch('/api/newsletter-subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      const data = await res.json();

      if (data.success) {
        form.style.display = 'none';
        success.classList.add('visible');
      } else {
        errorEl.textContent = data.error || 'Etwas ist schiefgelaufen. Versuch es nochmal.';
        errorEl.classList.add('visible');
        btn.disabled = false;
        btn.classList.remove('loading');
      }
    } catch {
      errorEl.textContent = 'Keine Verbindung. Bitte versuch es nochmal.';
      errorEl.classList.add('visible');
      btn.disabled = false;
      btn.classList.remove('loading');
    }
  });
</script>
