---
import stations from '../data/stations.json';
import config from '../data/config.json';
import { getCollection } from 'astro:content';

interface Props {
  height?: string;
  mapId?: string;
  showRoute?: boolean;
  showFilters?: boolean;
  currentStationId?: string;
}

const {
  height = '480px',
  mapId = 'trepper-map',
  showRoute = true,
  showFilters = false,
  currentStationId = config.currentStationId,
} = Astro.props;

// IDs die einen Erfahrungsbericht haben
const orteEntries = await getCollection('orte', ({ data }) => !data.draft);
const orteIds = orteEntries.map(o => o.data.stationId);

const stationsJSON = JSON.stringify(stations);
const orteIdsJSON  = JSON.stringify(orteIds);
const doRoute      = showRoute;
const doFilters    = showFilters;
---

<div class="map-outer-wrap">
  {showFilters && <div id={`${mapId}-filter`} class="map-filter-bar"></div>}
  <div
    id={`${mapId}-wrap`}
    style={`position:relative;height:${height};width:100%;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(15,23,42,0.13);border:3px solid white;outline:1px solid #E2E8F0;`}
  >
    <div id={mapId} style="height:100%;width:100%;"></div>
  </div>
</div>

<style>
  .map-outer-wrap { display: flex; flex-direction: column; gap: 0; width: 100%; }
  .map-filter-bar {
    display: flex;
    gap: 7px;
    flex-wrap: wrap;
    justify-content: center;
    padding: 8px 0 6px;
  }
</style>

<script is:inline define:vars={{ stationsJSON, orteIdsJSON, mapId, doRoute, doFilters, currentStationId }}>
(function() {
  function initMap() {
    if (typeof window.L === 'undefined') { setTimeout(initMap, 100); return; }

    var L        = window.L;
    var stations = JSON.parse(stationsJSON);
    var orteIds  = JSON.parse(orteIdsJSON);

    var map = L.map(mapId, { scrollWheelZoom: false, zoomControl: true });

    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      maxZoom: 18,
    }).addTo(map);

    var colorMap = {
      home:     '#8B5CF6',
      visited:  '#10B981',
      planned:  '#10B981', // wie visited
      upcoming: '#F97316',
      current:  '#F97316',
    };
    var labelMap = {
      home:     'Heimat',
      visited:  'Besucht',
      planned:  'Besucht',
      upcoming: 'Weltreise',
      current:  'Aktuell hier',
    };

    // LayerGroups — nur 3: home, visited, upcoming
    // planned fällt in visited-Gruppe (s. unten)
    var groups = {
      home:     L.layerGroup().addTo(map),
      visited:  L.layerGroup().addTo(map),
      upcoming: L.layerGroup().addTo(map),
    };

    // Route
    if (doRoute) {
      var coords = stations.map(function(s) { return [s.lat, s.lon]; });
      if (coords.length > 1) {
        L.polyline(coords, { color: '#ffffff', weight: 7, opacity: 0.7 }).addTo(map);
        L.polyline(coords, { color: '#F97316', weight: 4, opacity: 0.9, lineCap: 'round', lineJoin: 'round' }).addTo(map);
      }
    }

    // Marker
    stations.forEach(function(s) {
      var color  = colorMap[s.status] || '#94A3B8';
      var label  = labelMap[s.status] || s.status;
      var dim    = (s.status === 'upcoming') ? '0.65' : '1';
      var isHere = s.id === currentStationId;

      var icon;
      if (isHere) {
        // Großer "Du bist hier"-Marker: coral, doppelter Pulsring, weiße Mitte
        icon = L.divIcon({
          className: '',
          html: '<div style="position:relative;width:52px;height:52px;">'
              + '<div style="position:absolute;inset:0;border-radius:50%;background:#F97316;opacity:0.12;animation:mpulse 2s ease-in-out infinite;"></div>'
              + '<div style="position:absolute;inset:8px;border-radius:50%;background:#F97316;opacity:0.2;animation:mpulse 2s ease-in-out 0.7s infinite;"></div>'
              + '<div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:24px;height:24px;background:#F97316;border:3.5px solid white;border-radius:50%;box-shadow:0 0 0 2px #F97316,0 4px 16px #F9731666;"></div>'
              + '<div style="position:absolute;top:-18px;left:50%;transform:translateX(-50%);background:#F97316;color:white;font-size:9px;font-weight:800;font-family:system-ui,sans-serif;letter-spacing:.04em;padding:2px 6px;border-radius:100px;white-space:nowrap;box-shadow:0 2px 8px #F9731644;">HIER</div>'
              + '</div>',
          iconSize: [52, 52],
          iconAnchor: [26, 26],
        });
      } else {
        icon = L.divIcon({
          className: '',
          html: '<div style="position:relative;width:30px;height:30px;">'
              + '<div style="position:absolute;inset:0;border-radius:50%;background:' + color + ';opacity:0.18;animation:mpulse 2.5s ease-in-out infinite;"></div>'
              + '<div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:17px;height:17px;background:' + color + ';border:3px solid white;border-radius:50%;box-shadow:0 2px 10px ' + color + '80;opacity:' + dim + ';"></div>'
              + '</div>',
          iconSize: [30, 30],
          iconAnchor: [15, 15],
        });
      }

      var dateStr = '';
      if (s.dateFrom) {
        dateStr = new Date(s.dateFrom).toLocaleDateString('de-DE', { month: 'long', year: 'numeric' });
        if (s.dateTo) dateStr += ' – ' + new Date(s.dateTo).toLocaleDateString('de-DE', { month: 'short' });
      }

      var worldreiseNote = (s.status === 'upcoming')
        ? '<div style="margin-top:7px;font-size:0.72rem;color:#F97316;font-weight:700;">🌏 Weltreise · Abflug 9. Juni 2026</div>'
        : '';

      var reportLink = orteIds.indexOf(s.id) !== -1
        ? '<a href="/orte/' + s.id + '" style="display:inline-flex;align-items:center;gap:4px;margin-top:10px;font-size:0.78rem;font-weight:700;color:#F97316;text-decoration:none;background:#FFF7ED;border:1.5px solid #FDBA74;padding:4px 10px;border-radius:100px;">📖 Zum Erfahrungsbericht →</a>'
        : '';

      var hierBadge = isHere
        ? '<div style="display:inline-flex;align-items:center;gap:5px;background:#FFF7ED;border:1.5px solid #FDBA74;color:#C2410C;font-size:0.68rem;font-weight:800;text-transform:uppercase;letter-spacing:0.05em;padding:3px 9px;border-radius:100px;margin-bottom:8px;">📍 Aktueller Standort</div>'
        : '<div style="display:inline-block;background:' + color + '22;color:' + color + ';font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;padding:2px 9px;border-radius:100px;margin-bottom:8px;">' + label + '</div>';

      var marker = L.marker([s.lat, s.lon], { icon: icon });
      marker.bindPopup(
        '<div style="font-family:system-ui,sans-serif;min-width:175px;padding:4px 2px;">'
        + '<div style="font-size:1.4rem;margin-bottom:4px;">' + s.flag + '</div>'
        + '<div style="font-weight:800;font-size:1rem;color:#0F172A;margin-bottom:2px;">' + s.name + '</div>'
        + '<div style="color:#64748B;font-size:0.8rem;margin-bottom:8px;">' + s.country + '</div>'
        + hierBadge
        + '<div style="font-size:0.82rem;color:#475569;line-height:1.5;">' + s.description + '</div>'
        + (dateStr ? '<div style="margin-top:7px;font-size:0.75rem;color:' + color + ';font-weight:600;">' + dateStr + '</div>' : '')
        + worldreiseNote
        + reportLink
        + '</div>',
        { maxWidth: 250 }
      );

      // current + planned → in passende Gruppe einordnen
      var grp = s.status === 'current'
        ? groups['upcoming']
        : (groups[s.status] || groups['visited']);
      grp.addLayer(marker);
    });

    // Bounds
    var allCoords = stations.map(function(s) { return [s.lat, s.lon]; });
    map.fitBounds(L.latLngBounds(allCoords), { padding: [40, 40] });

    // ── FILTER BUTTONS ──────────────────────────────────────
    if (doFilters) {
      // Use external filter bar above map (better for mobile)
      var externalBar = document.getElementById(mapId + '-filter');

      var bar = document.createElement('div');
      if (externalBar) {
        // Render buttons in the bar above the map
        bar.style.cssText = 'display:contents;';
        externalBar.appendChild(bar);
      } else {
        // Fallback: absolute inside map
        var wrap = document.getElementById(mapId + '-wrap');
        bar.style.cssText = [
          'position:absolute',
          'bottom:14px',
          'left:50%',
          'transform:translateX(-50%)',
          'z-index:1000',
          'display:flex',
          'gap:7px',
          'flex-wrap:wrap',
          'justify-content:center',
          'padding:8px 12px',
          'background:rgba(255,255,255,0.92)',
          'backdrop-filter:blur(8px)',
          'border-radius:100px',
          'box-shadow:0 4px 20px rgba(15,23,42,0.13)',
          'border:1px solid #E2E8F0',
        ].join(';');
        wrap.appendChild(bar);
      }

      var filterDefs = [
        { status: 'home',     label: '🏠 Heimat',   color: '#8B5CF6' },
        { status: 'visited',  label: '✓ Besucht',   color: '#10B981' },
        { status: 'upcoming', label: '🌏 Weltreise', color: '#F97316' },
      ];

      filterDefs.forEach(function(def) {
        var btn = document.createElement('button');
        btn.textContent = def.label;
        btn.dataset.status = def.status;
        btn.dataset.active = 'true';
        setFilterStyle(btn, def.color, true);

        btn.addEventListener('click', function() {
          var active = this.dataset.active === 'true';
          active = !active;
          this.dataset.active = String(active);
          setFilterStyle(this, def.color, active);
          if (active) {
            groups[def.status].addTo(map);
          } else {
            map.removeLayer(groups[def.status]);
          }
        });

        bar.appendChild(btn);
      });
    }

    function setFilterStyle(btn, color, active) {
      btn.style.cssText = [
        'display:inline-flex',
        'align-items:center',
        'gap:5px',
        'padding:5px 13px',
        'border-radius:100px',
        'font-size:.75rem',
        'font-weight:700',
        'font-family:inherit',
        'cursor:pointer',
        'transition:all .15s',
        'border:2px solid ' + color,
        active
          ? 'background:' + color + ';color:#fff;'
          : 'background:#fff;color:' + color + ';opacity:0.6;',
      ].join(';');
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMap);
  } else {
    initMap();
  }
})();
</script>

<style is:global>
  @keyframes mpulse {
    0%, 100% { transform: scale(1);   opacity: 0.18; }
    50%       { transform: scale(2.2); opacity: 0; }
  }
  .leaflet-popup-content-wrapper {
    border-radius: 14px !important;
    box-shadow: 0 8px 32px rgba(15,23,42,0.18) !important;
    padding: 0 !important;
  }
  .leaflet-popup-content { margin: 14px 16px !important; }
  .leaflet-popup-tip-container { margin-top: -1px; }
</style>
