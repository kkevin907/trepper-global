---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const orte = await getCollection('orte', ({ data }) => !data.draft);

// Echte Berichte (kein TODO in highlights[0]) zuerst, dann nach Datum absteigend
const hasRealContent = (o: typeof orte[0]) => !o.data.highlights[0].startsWith('TODO');
orte.sort((a, b) => {
  const aReal = hasRealContent(a) ? 1 : 0;
  const bReal = hasRealContent(b) ? 1 : 0;
  if (bReal !== aReal) return bReal - aReal;
  return new Date(b.data.dateFrom).getTime() - new Date(a.data.dateFrom).getTime();
});

const costLabels = ['', 'Günstig', 'Mittel', 'Teuer'];
const costColors = ['', '#10B981', '#F97316', '#EF4444'];
---

<Layout
  title="Orte"
  description="Alle Orte, die Kevin besucht hat — persönliche Erfahrungsberichte, Food-Spots, Tipps und Highlights."
>

  <div class="oi-header">
    <div class="oi-header-inner">
      <a href="/" class="oi-back">← Zurück</a>
      <h1 class="oi-title">Meine Orte</h1>
      <p class="oi-sub">Persönliche Berichte aus jedem Ort — Food-Spots, Highlights, Tipps.</p>
    </div>
  </div>

  <div class="oi-wrap">
    <div class="oi-inner">

      {orte.length === 0 ? (
        <div class="oi-empty">
          <p>Noch keine Berichte veröffentlicht.</p>
        </div>
      ) : (
        <div class="oi-grid">
          {orte.map(ort => {
            const d = ort.data;
            const dateFrom = new Date(d.dateFrom).toLocaleDateString('de-DE', { day: 'numeric', month: 'short', year: 'numeric' });
            const dateTo   = new Date(d.dateTo).toLocaleDateString('de-DE', { day: 'numeric', month: 'short', year: 'numeric' });
            const stars    = '★'.repeat(d.rating) + '☆'.repeat(5 - d.rating);
            const euros    = '€'.repeat(d.costLevel);
            const isReal   = !d.highlights[0].startsWith('TODO');

            return (
              <a href={`/orte/${ort.id}`} class={`oi-card${isReal ? '' : ' oi-card--soon'}`}>
                {d.coverImage ? (
                  <div class="oi-card-img">
                    <img src={d.coverImage} alt={d.title} />
                  </div>
                ) : (
                  <div class="oi-card-img oi-card-img--empty">
                    <span class="oi-card-flag">{d.flag}</span>
                    {!isReal && <span class="oi-coming-soon">Bericht folgt bald</span>}
                  </div>
                )}
                <div class="oi-card-body">
                  <div class="oi-card-meta">
                    <span class="oi-card-country">{d.flag} {d.country}</span>
                    <span class="oi-card-nights">{d.nights} Nächte</span>
                  </div>
                  <h2 class="oi-card-title">{d.title}</h2>
                  <p class="oi-card-dates">{dateFrom} – {dateTo}</p>
                  <div class="oi-card-chips">
                    {isReal && <span class="oi-chip oi-chip-report">📖 Bericht lesen</span>}
                    <span class="oi-chip oi-chip-vibe">{d.vibe}</span>
                    <span class="oi-chip" style={`color:${costColors[d.costLevel]};border-color:${costColors[d.costLevel]}20;background:${costColors[d.costLevel]}10;`}>
                      {euros}
                    </span>
                    <span class="oi-chip oi-chip-stars">{stars}</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      )}

    </div>
  </div>

</Layout>

<style>
  /* HEADER */
  .oi-header {
    background: linear-gradient(160deg, #F8FAFC 0%, #ffffff 60%);
    border-bottom: 1px solid var(--border);
    padding: 2.5rem 1.5rem;
  }
  .oi-header-inner { max-width: 1100px; margin: 0 auto; }

  .oi-back {
    display: inline-block;
    font-size: .82rem;
    font-weight: 600;
    color: var(--text-mid);
    margin-bottom: 1.25rem;
    text-decoration: none;
    transition: color .15s;
  }
  .oi-back:hover { color: var(--coral); }

  .oi-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -.04em;
    color: var(--text);
    margin-bottom: .4rem;
  }
  .oi-sub {
    font-size: .95rem;
    color: var(--text-mid);
    max-width: 540px;
  }

  /* LAYOUT */
  .oi-wrap  { padding: 2.5rem 1.5rem 5rem; }
  .oi-inner { max-width: 1100px; margin: 0 auto; }

  .oi-empty {
    text-align: center;
    padding: 4rem;
    color: var(--text-light);
    font-size: .9rem;
  }

  /* GRID */
  .oi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  /* CARD */
  .oi-card {
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border: 1.5px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    transition: box-shadow .2s, transform .2s;
  }
  .oi-card:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,.08);
    transform: translateY(-2px);
  }

  .oi-card-img {
    height: 180px;
    overflow: hidden;
    background: #F1F5F9;
  }
  .oi-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .3s;
  }
  .oi-card:hover .oi-card-img img { transform: scale(1.04); }

  .oi-card-img--empty {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #F8FAFC, #F1F5F9);
  }
  .oi-card-flag { font-size: 3.5rem; }

  .oi-card-body { padding: 1.1rem 1.25rem 1.25rem; }

  .oi-card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: .45rem;
  }
  .oi-card-country {
    font-size: .75rem;
    font-weight: 600;
    color: var(--text-light);
    text-transform: uppercase;
    letter-spacing: .05em;
  }
  .oi-card-nights {
    font-size: .72rem;
    font-weight: 600;
    color: var(--text-light);
    background: #F1F5F9;
    padding: 2px 8px;
    border-radius: 100px;
  }

  .oi-card-title {
    font-size: 1.35rem;
    font-weight: 800;
    letter-spacing: -.03em;
    color: var(--text);
    margin-bottom: .2rem;
  }
  .oi-card-dates {
    font-size: .78rem;
    color: var(--text-light);
    margin-bottom: .75rem;
  }

  .oi-card-chips { display: flex; flex-wrap: wrap; gap: .4rem; }
  .oi-chip {
    display: inline-block;
    padding: .22rem .65rem;
    border-radius: 100px;
    font-size: .72rem;
    font-weight: 600;
    border: 1.5px solid var(--border);
    background: #F8FAFC;
    color: var(--text-mid);
    white-space: nowrap;
  }
  .oi-chip-vibe { background: var(--coral-light); color: #C2410C; border-color: var(--coral-mid); }
  .oi-chip-stars  { color: #F59E0B; letter-spacing: 1px; border-color: #FEF3C720; background: #FEF3C730; }
  .oi-chip-report { background: var(--coral-light); color: #C2410C; border-color: var(--coral-mid); }

  /* Coming soon cards */
  .oi-card--soon { opacity: .72; }
  .oi-card--soon:hover { opacity: 1; }
  .oi-coming-soon {
    position: absolute;
    bottom: .6rem;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(15,23,42,.55);
    color: #fff;
    font-size: .72rem;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 100px;
    white-space: nowrap;
    backdrop-filter: blur(4px);
  }
  .oi-card-img--empty { position: relative; }

  /* RESPONSIVE */
  @media (max-width: 600px) {
    .oi-grid { grid-template-columns: 1fr; }
  }
</style>
