---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Seite nicht gefunden" description="Diese Seite existiert nicht — aber die Reise geht weiter.">
  <div class="nf-wrap">

    <!-- Riesige 404 im Hintergrund -->
    <div class="nf-bg-number" aria-hidden="true">404</div>

    <!-- Animierte Route quer über den Screen -->
    <div class="nf-route-line" aria-hidden="true">
      <svg viewBox="0 0 1200 120" preserveAspectRatio="none" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path
          id="route-path"
          d="M -50 60 C 150 20, 250 95, 400 55 C 550 15, 620 85, 780 50 C 900 25, 1000 80, 1250 45"
          stroke="#F97316"
          stroke-width="2.5"
          stroke-dasharray="10 8"
          stroke-linecap="round"
          fill="none"
        />
      </svg>
      <!-- Pulsierender Punkt am Ende der Route -->
      <div class="nf-pulse-dot">
        <div class="nf-pulse-ring"></div>
        <div class="nf-pulse-core"></div>
      </div>
    </div>

    <!-- Inhalt -->
    <div class="nf-content">
      <div class="nf-badge">
        <span class="nf-badge-dot"></span>
        Koordinaten nicht gefunden
      </div>

      <h1 class="nf-headline">Irgendwo verloren gegangen.</h1>

      <p class="nf-sub">
        Diese Seite existiert nicht — aber die Reise geht weiter.
      </p>

      <div class="nf-coords" aria-hidden="true">
        <span>40°4'0"N</span>
        <span class="nf-coords-sep">·</span>
        <span>4°04'0"E</span>
        <span class="nf-coords-sep">·</span>
        <span>404m ü. NN</span>
      </div>

      <div class="nf-actions">
        <a href="/" class="nf-btn nf-btn--primary">Zur Startseite</a>
        <a href="/logbook" class="nf-btn nf-btn--ghost">Zum Logbuch</a>
      </div>

      <a href="javascript:history.back()" class="nf-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
        Zurück zur letzten Seite
      </a>
    </div>

  </div>
</Layout>

<style>
  .nf-wrap {
    min-height: calc(100vh - 140px);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 4rem 1.5rem;
  }

  /* ── Riesige 404 im Hintergrund ── */
  .nf-bg-number {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -52%);
    font-size: clamp(16rem, 40vw, 28rem);
    font-weight: 900;
    letter-spacing: -.06em;
    color: #F1F5F9;
    line-height: 1;
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
    animation: nf-fade-in 0.8s ease both;
  }

  /* ── Animierte Route ── */
  .nf-route-line {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    height: 120px;
    pointer-events: none;
  }

  .nf-route-line svg {
    width: 100%;
    height: 100%;
  }

  .nf-route-line svg path {
    stroke-dasharray: 10 8;
    stroke-dashoffset: 800;
    animation: nf-draw-route 2s cubic-bezier(.4,0,.2,1) 0.3s forwards;
    opacity: 0.35;
  }

  @keyframes nf-draw-route {
    from {
      stroke-dashoffset: 800;
      opacity: 0;
    }
    10% { opacity: 0.35; }
    to {
      stroke-dashoffset: 0;
      opacity: 0.35;
    }
  }

  /* ── Pulsierender Punkt ── */
  .nf-pulse-dot {
    position: absolute;
    right: calc(100% / 12);
    top: 50%;
    transform: translate(50%, -50%);
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    animation: nf-appear 0.4s ease 2s forwards;
  }

  .nf-pulse-ring {
    position: absolute;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #F9731620;
    animation: nf-ping 1.6s ease-out 2.2s infinite;
  }

  .nf-pulse-core {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--coral);
    border: 2.5px solid white;
    box-shadow: 0 0 0 2px var(--coral), 0 2px 8px rgba(249,115,22,0.4);
    position: relative;
    z-index: 1;
  }

  @keyframes nf-ping {
    0%   { transform: scale(1); opacity: 0.6; }
    100% { transform: scale(2.5); opacity: 0; }
  }

  @keyframes nf-appear {
    to { opacity: 1; }
  }

  /* ── Inhalt ── */
  .nf-content {
    position: relative;
    z-index: 10;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    animation: nf-fade-up 0.7s ease 0.1s both;
  }

  @keyframes nf-fade-up {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes nf-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* Badge */
  .nf-badge {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    background: var(--coral-light);
    color: #C2410C;
    font-size: .75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    padding: .3rem .9rem;
    border-radius: 100px;
    border: 1.5px solid #FDBA74;
  }

  .nf-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--coral);
    display: inline-block;
  }

  /* Headline */
  .nf-headline {
    font-size: clamp(2rem, 6vw, 3.75rem);
    font-weight: 900;
    letter-spacing: -.04em;
    line-height: 1.05;
    color: var(--text);
    max-width: 18ch;
  }

  /* Subtext */
  .nf-sub {
    font-size: clamp(.95rem, 2vw, 1.15rem);
    color: var(--text-mid);
    line-height: 1.6;
    max-width: 40ch;
  }

  /* Koordinaten */
  .nf-coords {
    display: flex;
    align-items: center;
    gap: .5rem;
    font-size: .78rem;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
    color: var(--text-light);
    background: var(--bg-soft);
    border: 1.5px solid var(--border);
    padding: .4rem 1rem;
    border-radius: 100px;
    letter-spacing: .04em;
  }

  .nf-coords-sep { color: var(--border); }

  /* Buttons */
  .nf-actions {
    display: flex;
    gap: .75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: .25rem;
  }

  .nf-btn {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    padding: .75rem 1.75rem;
    border-radius: 100px;
    font-size: .9rem;
    font-weight: 700;
    letter-spacing: -.01em;
    transition: all .18s ease;
    white-space: nowrap;
  }

  .nf-btn--primary {
    background: var(--coral);
    color: white;
    box-shadow: 0 4px 16px rgba(249,115,22,0.3);
  }
  .nf-btn--primary:hover {
    background: #EA6A0A;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(249,115,22,0.4);
  }

  .nf-btn--ghost {
    background: white;
    color: var(--text);
    border: 1.5px solid var(--border);
  }
  .nf-btn--ghost:hover {
    border-color: #CBD5E1;
    background: var(--bg-soft);
    transform: translateY(-2px);
  }

  /* Zurück-Link */
  .nf-back {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    font-size: .82rem;
    color: var(--text-light);
    transition: color .15s;
    margin-top: -.25rem;
  }
  .nf-back:hover { color: var(--text-mid); }

  /* Mobile */
  @media (max-width: 600px) {
    .nf-bg-number {
      font-size: clamp(10rem, 55vw, 16rem);
    }
    .nf-coords {
      font-size: .7rem;
      flex-wrap: wrap;
      justify-content: center;
    }
    .nf-btn { padding: .7rem 1.4rem; }
  }
</style>
