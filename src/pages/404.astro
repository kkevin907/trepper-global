---
import Layout from '../layouts/Layout.astro';
import WorldMap from '../components/WorldMap.astro';
---

<Layout title="404 — Seite nicht gefunden" description="Diese Seite existiert nicht — aber die Reise geht weiter.">

  <!-- HERO -->
  <div class="nf-wrap">
    <div class="nf-bg-number" aria-hidden="true">404</div>

    <div class="nf-route-line" aria-hidden="true">
      <svg viewBox="0 0 1200 120" preserveAspectRatio="none" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path
          d="M -50 60 C 150 20, 250 95, 400 55 C 550 15, 620 85, 780 50 C 900 25, 1000 80, 1250 45"
          stroke="#F97316"
          stroke-width="2.5"
          stroke-dasharray="10 8"
          stroke-linecap="round"
        />
      </svg>
      <div class="nf-pulse-dot">
        <div class="nf-pulse-ring"></div>
        <div class="nf-pulse-core"></div>
      </div>
    </div>

    <div class="nf-content">
      <div class="nf-badge">
        <span class="nf-badge-dot"></span>
        Koordinaten nicht gefunden
      </div>

      <h1 class="nf-headline">Irgendwo verloren gegangen.</h1>

      <p class="nf-sub">
        Diese Seite existiert nicht — aber die Reise geht weiter.
      </p>

      <div class="nf-coords" aria-hidden="true">
        <span>40°4'0"N</span>
        <span class="nf-coords-sep">·</span>
        <span>4°04'0"E</span>
        <span class="nf-coords-sep">·</span>
        <span>404m ü. NN</span>
      </div>

      <div class="nf-actions">
        <a href="/" class="nf-btn nf-btn--primary">Zur Startseite</a>
        <a href="/logbook" class="nf-btn nf-btn--ghost">Zum Logbuch</a>
      </div>

      <a href="javascript:history.back()" class="nf-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
        Zurück zur letzten Seite
      </a>
    </div>
  </div>

  <!-- KARTEN-SEKTION -->
  <div class="nf-map-section">
    <div class="nf-map-inner">
      <div class="nf-map-header">
        <p class="nf-map-label">Vielleicht hilft das weiter</p>
        <h2 class="nf-map-title">Alle besuchten Orte auf einen Blick</h2>
        <p class="nf-map-sub">Klick auf einen Marker um mehr zu erfahren — oder stöbere durch die Berichte.</p>
      </div>

      <WorldMap height="400px" mapId="nf-map" showRoute={false} showFilters={false} />

      <div class="nf-map-footer">
        <a href="/orte" class="nf-map-link">
          Alle Reiseberichte ansehen
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
        <a href="/route" class="nf-map-link">
          Route &amp; Timeline
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      </div>
    </div>
  </div>

</Layout>

<style>
  /* ── HERO ── */
  .nf-wrap {
    min-height: calc(100vh - 140px);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 4rem 1.5rem;
  }

  .nf-bg-number {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -52%);
    font-size: clamp(16rem, 40vw, 28rem);
    font-weight: 900;
    letter-spacing: -.06em;
    color: #F1F5F9;
    line-height: 1;
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
    animation: nf-fade-in 0.8s ease forwards;
  }

  .nf-route-line {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    pointer-events: none;
  }
  .nf-route-line svg {
    width: 100%;
    height: 120px;
    opacity: 0.3;
    animation: nf-fade-in 1.2s ease 0.5s forwards;
  }

  .nf-pulse-dot {
    position: absolute;
    right: 8%;
    top: 50%;
    transform: translateY(-50%);
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    animation: nf-fade-in 0.4s ease 1.5s forwards;
  }
  .nf-pulse-ring {
    position: absolute;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(249,115,22,0.15);
    animation: nf-ping 1.8s ease-out 1.8s infinite;
  }
  .nf-pulse-core {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--coral);
    border: 2.5px solid white;
    box-shadow: 0 0 0 2px var(--coral), 0 2px 8px rgba(249,115,22,0.4);
    position: relative;
    z-index: 1;
  }

  @keyframes nf-ping {
    0%   { transform: scale(1);   opacity: 0.7; }
    100% { transform: scale(2.8); opacity: 0; }
  }
  @keyframes nf-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes nf-fade-up {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .nf-content {
    position: relative;
    z-index: 10;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    animation: nf-fade-up 0.6s ease forwards;
  }

  .nf-badge {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    background: var(--coral-light);
    color: #C2410C;
    font-size: .75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    padding: .3rem .9rem;
    border-radius: 100px;
    border: 1.5px solid #FDBA74;
  }
  .nf-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--coral);
  }

  .nf-headline {
    font-size: clamp(2rem, 6vw, 3.75rem);
    font-weight: 900;
    letter-spacing: -.04em;
    line-height: 1.05;
    color: var(--text);
    max-width: 18ch;
  }
  .nf-sub {
    font-size: clamp(.95rem, 2vw, 1.1rem);
    color: var(--text-mid);
    line-height: 1.6;
    max-width: 42ch;
  }

  .nf-coords {
    display: flex;
    align-items: center;
    gap: .5rem;
    font-size: .78rem;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
    color: var(--text-light);
    background: var(--bg-soft);
    border: 1.5px solid var(--border);
    padding: .4rem 1rem;
    border-radius: 100px;
    letter-spacing: .04em;
  }
  .nf-coords-sep { color: var(--border); }

  .nf-actions {
    display: flex;
    gap: .75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: .25rem;
  }
  .nf-btn {
    display: inline-flex;
    align-items: center;
    padding: .75rem 1.75rem;
    border-radius: 100px;
    font-size: .9rem;
    font-weight: 700;
    transition: all .18s ease;
    white-space: nowrap;
  }
  .nf-btn--primary {
    background: var(--coral);
    color: white;
    box-shadow: 0 4px 16px rgba(249,115,22,0.3);
  }
  .nf-btn--primary:hover { background: #EA6A0A; transform: translateY(-2px); box-shadow: 0 6px 20px rgba(249,115,22,0.4); }
  .nf-btn--ghost {
    background: white;
    color: var(--text);
    border: 1.5px solid var(--border);
  }
  .nf-btn--ghost:hover { border-color: #CBD5E1; background: var(--bg-soft); transform: translateY(-2px); }

  .nf-back {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    font-size: .82rem;
    color: var(--text-light);
    transition: color .15s;
    margin-top: -.25rem;
  }
  .nf-back:hover { color: var(--text-mid); }

  /* ── KARTEN-SEKTION ── */
  .nf-map-section {
    background: var(--bg-soft);
    border-top: 1.5px solid var(--border);
    padding: 3rem 1.5rem 4rem;
  }
  .nf-map-inner {
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .nf-map-header { text-align: center; }
  .nf-map-label {
    font-size: .75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--text-light);
    margin-bottom: .5rem;
  }
  .nf-map-title {
    font-size: clamp(1.3rem, 3vw, 1.75rem);
    font-weight: 800;
    letter-spacing: -.03em;
    color: var(--text);
    margin-bottom: .5rem;
  }
  .nf-map-sub {
    font-size: .9rem;
    color: var(--text-mid);
    line-height: 1.6;
  }

  .nf-map-footer {
    display: flex;
    justify-content: center;
    gap: 2.5rem;
    flex-wrap: wrap;
  }
  .nf-map-link {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    font-size: .9rem;
    font-weight: 700;
    color: var(--coral);
    transition: gap .15s;
  }
  .nf-map-link:hover { gap: .65rem; }

  @media (max-width: 600px) {
    .nf-bg-number { font-size: clamp(10rem, 55vw, 16rem); }
    .nf-coords { font-size: .7rem; flex-wrap: wrap; justify-content: center; }
    .nf-btn { padding: .7rem 1.4rem; min-height: 44px; }
    .nf-actions { flex-direction: column; width: 100%; max-width: 280px; }
    .nf-actions .nf-btn { justify-content: center; }
    .nf-map-section { padding: 2rem 1.25rem 3rem; }
  }
</style>
