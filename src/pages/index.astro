---
import Layout from '../layouts/Layout.astro';
import LocationBadge from '../components/LocationBadge.astro';
import WorldMap from '../components/WorldMap.astro';
import stationsData from '../data/stations.json';
import config from '../data/config.json';
import { getCollection } from 'astro:content';

const orteEntries = await getCollection('orte', ({ data }) => !data.draft);
const orteIdSet = new Set(orteEntries.filter(o => !o.data.highlights[0].startsWith('TODO')).map(o => o.data.stationId));
const orteCount = orteIdSet.size;

// Warmup-Stops die bereits besucht wurden
const warmupVisited = stationsData.filter(s => s.phase === 'warmup' && s.status === 'visited').length;


const target   = new Date('2026-06-09T00:00:00');
const now      = new Date();
const daysLeft = Math.max(0, Math.ceil((target.getTime() - now.getTime()) / 86400000));
const started  = daysLeft <= 0;

// Kilometer berechnen — Haversine über alle besuchten Stationen (home + visited)
function haversine(lat1: number, lon1: number, lat2: number, lon2: number): number {
  const R = 6371;
  const dLat = (lat2 - lat1) * Math.PI / 180;
  const dLon = (lon2 - lon1) * Math.PI / 180;
  const a = Math.sin(dLat/2) ** 2
    + Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) * Math.sin(dLon/2) ** 2;
  return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
}

// km zurückgelegt — nur Weltreise (phase "main"), ab Solingen, chronologisch
const home = stationsData.find(s => s.status === 'home')!;
const worldTripVisited = stationsData
  .filter(s => s.phase === 'main' && (s.status === 'visited' || s.status === 'current') && s.dateFrom)
  .sort((a, b) => new Date(a.dateFrom!).getTime() - new Date(b.dateFrom!).getTime());

const traveled = worldTripVisited.length > 0 ? [home, ...worldTripVisited] : [];

let kmTotal = 0;
for (let i = 1; i < traveled.length; i++) {
  kmTotal += haversine(traveled[i-1].lat, traveled[i-1].lon, traveled[i].lat, traveled[i].lon);
}
const kmDisplay = kmTotal > 0
  ? Math.round(kmTotal).toLocaleString('de-DE')
  : '0';


// Aktueller Standort — gesteuert über src/data/config.json → currentStationId
const currentStation = stationsData.find(s => s.id === config.currentStationId)
  || stationsData.find(s => s.status === 'home')!;
const solingen = stationsData.find(s => s.id === 'solingen')!;
const distKm = Math.round(haversine(solingen.lat, solingen.lon, currentStation.lat, currentStation.lon));
const distDisplay = distKm === 0 ? 'Heimat' : `${distKm.toLocaleString('de-DE')} km`;
const locTimezone = currentStation.timezone || 'Europe/Berlin';
// Währungsname auf Deutsch via Intl.DisplayNames
const currencyNames = new Intl.DisplayNames(['de'], { type: 'currency' });
const locCurrencyName = currencyNames.of(currentStation.currency) || currentStation.currency;
const locCurrencyDisplay = `${currentStation.currencySymbol} ${locCurrencyName}`;
const locStationName = currentStation.name;
const locLat = currentStation.lat;
const locLon = currentStation.lon;
---

<Layout title="Home">
<div class="pg-home">

<!-- ═══════════════════════════════════════════════════════
     HERO — 2-Spalten: Text links, Karte sofort sichtbar rechts
═══════════════════════════════════════════════════════ -->
<section class="ph-hero">
  <div class="ph-blob ph-b1"></div>
  <div class="ph-blob ph-b2"></div>
  <div class="ph-blob ph-b3"></div>

  <div class="ph-hero-inner">

    <!-- LINKE SPALTE: kompakter Text -->
    <div class="ph-hero-left">

      <!-- Ortsinfo-Strip: Uhrzeit, Währung, Standort, Wetter -->
      <div class="ph-locinfo" id="ph-locinfo" data-tz={locTimezone} data-lat={locLat} data-lon={locLon} data-currency={currentStation.currency} data-symbol={currentStation.currencySymbol}>

        <div class="ph-li-block">
          <span class="ph-li-label">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Lokale Uhrzeit
          </span>
          <span class="ph-li-val">
            <span id="ph-li-time" class="ph-li-time">--:--:--</span>
          </span>
        </div>

        <div class="ph-li-sep"></div>

        <div class="ph-li-block">
          <span class="ph-li-label">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            Währung vor Ort
          </span>
          <span class="ph-li-val">{locCurrencyDisplay}</span>
          <span class="ph-li-rate" id="ph-li-rate"></span>
        </div>

        <div class="ph-li-sep"></div>

        <div class="ph-li-block">
          <span class="ph-li-label">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a5 5 0 1 0 5 5"/><path d="M12 2v2M12 12v2M4.22 4.22l1.42 1.42M18.36 5.64l1.42-1.42M2 12h2M20 12h2"/><circle cx="16" cy="6" r="3"/></svg>
            Wetter vor Ort
          </span>
          <span class="ph-li-val" id="ph-li-weather">
            <span id="ph-weather-icon" style="font-size:.95rem;line-height:1;">–</span>
            <span id="ph-weather-temp" class="ph-li-time" style="width:auto;min-width:38px;">–°</span>
          </span>
        </div>

      </div>

      <!-- Topbar: Standort + Countdown -->
      <div class="ph-topbar">
        <LocationBadge location={currentStation.name} country={currentStation.country} flag={currentStation.flag} />
        {!started ? (
          <div class="ph-chip">
            <span class="ph-chip-num">{daysLeft}</span>
            <span class="ph-chip-txt">Tage</span>
          </div>
        ) : (
          <div class="ph-chip ph-chip-go">
            <span class="ph-chip-txt">🌏 Unterwegs!</span>
          </div>
        )}
      </div>

      <!-- Kompakte Headline -->
      <div class="ph-headline-block">
        <p class="ph-eyebrow">Persönliches Reise-Logbuch</p>
        <h1 class="ph-title">
          Von Solingen<br />
          <span class="ph-grad">in die Welt.</span>
        </h1>
        <p class="ph-sub">
          Von Solingen nach Asien — alle Stops, alle Geschichten, live mitverfolgen.
        </p>
      </div>

      <!-- Buttons -->
      <div class="ph-actions">
        <a href="/logbook" class="ph-btn-primary">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          Logbuch lesen
        </a>
        <a href="/route" class="ph-btn-secondary">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          Route
        </a>
        <a href="/about" class="ph-btn-ghost">Über mich</a>
      </div>

      <!-- Stats -->
      <div class="ph-stats">
        <div class="ph-stat">
          <span class="ph-stat-n" style="color:#F97316;">{warmupVisited}</span>
          <span class="ph-stat-l">Orte in 2026</span>
        </div>
        <div class="ph-stat-sep"></div>
        <div class="ph-stat">
          <span class="ph-stat-n" style="color:#0EA5E9;">{orteCount}</span>
          <span class="ph-stat-l">Reiseberichte</span>
        </div>
        <div class="ph-stat-sep"></div>
        <div class="ph-stat">
          <span class="ph-stat-n" style="color:#10B981;">{started ? '🛫' : daysLeft}</span>
          <span class="ph-stat-l">{started ? 'Unterwegs!' : 'Tage bis Abflug'}</span>
        </div>
        <div class="ph-stat-sep"></div>
        <div class="ph-stat">
          <span class="ph-stat-n" style="color:#8B5CF6;">{kmDisplay || '0'}</span>
          <span class="ph-stat-l">km Weltreise</span>
        </div>
      </div>

    </div>

    <!-- RECHTE SPALTE: Karte direkt sichtbar -->
    <div class="ph-hero-right">
      <WorldMap height="100%" mapId="home-map" showRoute={false} showFilters={true} />
    </div>

  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     PHASEN — direkt danach, kompakt
═══════════════════════════════════════════════════════ -->
<section class="ph-sec ph-sec-soft reveal">
  <div class="ph-wrap">
    <div class="ph-sec-label" style="color:#F97316;">Der Plan</div>
    <h2 class="ph-sec-title">Mein 2026</h2>
    <p class="ph-sec-sub">Alle Stops — zieh die Timeline nach rechts für die Weltreise.</p>

    <div class="ph-tl-outer">
      <div class="ph-tl-scroll" id="ph-timeline">
        <div class="ph-tl">

          <!-- ✓ DONE: grün, solid lines -->
          {[
            { flag:'🇳🇱', name:'Renesse',   badge:'✓ Apr', id:'renesse' },
            { flag:'🇬🇧', name:'London',    badge:'✓ Apr', id:'london' },
            { flag:'🇵🇹', name:'Madeira',   badge:'✓ Apr', id:'madeira' },
            { flag:'🇵🇹', name:'Lissabon',  badge:'✓ Apr', id:'lissabon' },
            { flag:'🇪🇸', name:'Madrid',    badge:'✓ Apr', id:'madrid' },
            { flag:'🇪🇸', name:'Ibiza',     badge:'✓ Apr', id:'ibiza' },
            { flag:'🇲🇦', name:'Essaouira', badge:'✓ Mai', id:'essaouira' },
            { flag:'🇲🇦', name:'Taghazout', badge:'✓ Mai', id:'taghazout' },
          ].map((s) => (
            <>
              <div class="ph-tl-stop">
                <div class="ph-tl-top">
                  <span class="ph-tl-flag">{s.flag}</span>
                  {orteIdSet.has(s.id)
                    ? <a href={`/orte/${s.id}`} class="ph-tl-name ph-tl-name--link">{s.name}</a>
                    : <span class="ph-tl-name">{s.name}</span>
                  }
                </div>
                <div class="ph-tl-dot-row">
                  <div class="ph-tl-dot" style="background:#10B981;box-shadow:0 0 0 3px #10B98122;"></div>
                </div>
                <div class="ph-tl-bot">
                  <span class="ph-tl-badge" style="background:#D1FAE5;color:#065F46;">{s.badge}</span>
                </div>
              </div>
              <div class="ph-tl-line tl-solid"></div>
            </>
          ))}

          <!-- 🌏 START — Abflug 9. Juni -->
          <div class="ph-tl-start" id="ph-tl-start-marker">
            <div class="ph-tl-top"><span class="ph-tl-start-label">Abflug<br/>Asien</span></div>
            <div class="ph-tl-dot-row"><div class="ph-tl-start-dot">🌏</div></div>
            <div class="ph-tl-bot"><span class="ph-tl-badge" style="background:#FFF7ED;color:#C2410C;border:1.5px solid #FDBA74;">9. Juni</span></div>
          </div>
          <div class="ph-tl-line tl-dash"></div>

          <!-- Istanbul Zwischenstopp — grün nach 10. Juni, sonst orange -->
          {(() => {
            const istanbulDone = new Date() > new Date('2026-06-10T23:59:59');
            return (
              <div class="ph-tl-stop">
                <div class="ph-tl-top">
                  <span class="ph-tl-flag">🇹🇷</span>
                  <span class="ph-tl-name">Istanbul</span>
                </div>
                <div class="ph-tl-dot-row">
                  <div class="ph-tl-dot" style={`background:${istanbulDone ? '#10B981' : '#F97316'};opacity:${istanbulDone ? '1' : '.6'};box-shadow:0 0 0 3px ${istanbulDone ? '#10B98122' : '#F9731618'};`}></div>
                </div>
                <div class="ph-tl-bot">
                  <span class="ph-tl-badge" style={`background:${istanbulDone ? '#D1FAE5' : '#FFF7ED'};color:${istanbulDone ? '#065F46' : '#C2410C'};`}>
                    {istanbulDone ? '✓ 9.–10. Jun' : '9.–10. Jun'}
                  </span>
                </div>
              </div>
            );
          })()}
          <div class="ph-tl-line tl-dash"></div>

          <!-- GEPLANT: orange, dashed -->
          {[
            { flag:'🇹🇭', name:'Bangkok',      date:'ab 11. Jun' },
            { flag:'🇭🇰', name:'Hongkong',     date:'ab 2. Jul'  },
            { flag:'🇻🇳', name:'Vietnam'       },
            { flag:'🇲🇾', name:'Kuala Lumpur'  },
            { flag:'🇮🇩', name:'Bali'          },
            { flag:'🇳🇿', name:'Neuseeland'    },
          ].map((s, i, arr) => (
            <>
              <div class="ph-tl-stop">
                <div class="ph-tl-top">
                  <span class="ph-tl-flag">{s.flag}</span>
                  <span class="ph-tl-name">{s.name}</span>
                </div>
                <div class="ph-tl-dot-row">
                  <div class="ph-tl-dot" style="background:#F97316;opacity:.6;box-shadow:0 0 0 3px #F9731618;"></div>
                </div>
                <div class="ph-tl-bot">
                  <span class="ph-tl-badge" style="background:#FFF7ED;color:#C2410C;">{s.date ?? 'Geplant'}</span>
                </div>
              </div>
              {i < arr.length - 1 && <div class="ph-tl-line tl-dash"></div>}
            </>
          ))}

          <div class="ph-tl-line tl-dash"></div>
          <div class="ph-tl-stop" style="opacity:.38;">
            <div class="ph-tl-top"><span class="ph-tl-flag">🌍</span><span class="ph-tl-name">& mehr</span></div>
            <div class="ph-tl-dot-row"><div class="ph-tl-dot" style="background:white;border:2px dashed #CBD5E1;"></div></div>
            <div class="ph-tl-bot"><span class="ph-tl-badge" style="background:#F1F5F9;color:#94A3B8;">TBD</span></div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
(function () {
  function initTimeline() {
    var container = document.getElementById('ph-timeline');
    var marker    = document.getElementById('ph-tl-start-marker');
    if (!container || !marker) return;

    // 🌏-Marker zentrieren
    function centerMarker() {
      var cw = container.offsetWidth;
      var ml = marker.offsetLeft;
      var mw = marker.offsetWidth;
      container.scrollLeft = ml - cw / 2 + mw / 2;
    }
    centerMarker();
    window.addEventListener('resize', centerMarker);

    // Maus-Drag
    var isDown = false, startX = 0, scrollLeft = 0;
    container.style.cursor = 'grab';

    container.addEventListener('mousedown', function (e) {
      isDown = true;
      container.style.cursor = 'grabbing';
      startX     = e.pageX - container.offsetLeft;
      scrollLeft = container.scrollLeft;
    });
    document.addEventListener('mouseup', function () {
      isDown = false;
      container.style.cursor = 'grab';
    });
    container.addEventListener('mousemove', function (e) {
      if (!isDown) return;
      e.preventDefault();
      var x = e.pageX - container.offsetLeft;
      container.scrollLeft = scrollLeft - (x - startX) * 1.5;
    });
  }

  // Wechselkurs via Frankfurter API (kostenlos, kein API-Key)
  function initExchangeRate() {
    var el = document.getElementById('ph-locinfo');
    var rateEl = document.getElementById('ph-li-rate');
    if (!el || !rateEl) return;

    var currency = el.getAttribute('data-currency');
    var symbol   = el.getAttribute('data-symbol');
    if (!currency || currency === 'EUR') return; // Heimatwährung, kein Kurs nötig

    fetch('https://api.frankfurter.app/latest?from=EUR&to=' + currency)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var rate = data.rates && data.rates[currency];
        if (!rate) return;
        var formatted = rate >= 100
          ? Math.round(rate).toLocaleString('de-DE')
          : rate.toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        rateEl.textContent = '1 € = ' + formatted + ' ' + symbol;
      })
      .catch(function() {});
  }

  // Wetter via Open-Meteo (kostenlos, kein API-Key)
  function initWeather() {
    var el = document.getElementById('ph-locinfo');
    if (!el) return;
    var lat = el.getAttribute('data-lat');
    var lon = el.getAttribute('data-lon');
    if (!lat || !lon) return;

    // WMO Wettercodes → Emoji + Beschreibung
    var wmoMap = {
      0:  { e: '☀️',  t: 'Klar' },
      1:  { e: '🌤️', t: 'Meist klar' },
      2:  { e: '⛅',  t: 'Bewölkt' },
      3:  { e: '☁️',  t: 'Bedeckt' },
      45: { e: '🌫️', t: 'Nebel' },
      48: { e: '🌫️', t: 'Nebel' },
      51: { e: '🌦️', t: 'Nieselregen' },
      53: { e: '🌦️', t: 'Nieselregen' },
      55: { e: '🌦️', t: 'Nieselregen' },
      61: { e: '🌧️', t: 'Regen' },
      63: { e: '🌧️', t: 'Regen' },
      65: { e: '🌧️', t: 'Starkregen' },
      71: { e: '🌨️', t: 'Schnee' },
      73: { e: '🌨️', t: 'Schnee' },
      75: { e: '❄️',  t: 'Schneefall' },
      77: { e: '🌨️', t: 'Schneekörner' },
      80: { e: '🌦️', t: 'Schauer' },
      81: { e: '🌧️', t: 'Schauer' },
      82: { e: '⛈️',  t: 'Starke Schauer' },
      85: { e: '🌨️', t: 'Schneeschauer' },
      86: { e: '🌨️', t: 'Schneeschauer' },
      95: { e: '⛈️',  t: 'Gewitter' },
      96: { e: '⛈️',  t: 'Gewitter' },
      99: { e: '⛈️',  t: 'Schweres Gewitter' },
    };

    function fetchWeather() {
      var url = 'https://api.open-meteo.com/v1/forecast'
        + '?latitude=' + lat
        + '&longitude=' + lon
        + '&current=temperature_2m,weather_code'
        + '&timezone=auto';

      fetch(url)
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var cur = data.current;
          var code = cur.weather_code;
          var temp = Math.round(cur.temperature_2m);
          var info = wmoMap[code] || { e: '🌡️', t: '' };

          var iconEl = document.getElementById('ph-weather-icon');
          var tempEl = document.getElementById('ph-weather-temp');
          if (iconEl) iconEl.textContent = info.e;
          if (tempEl) tempEl.textContent = temp + '°C';
        })
        .catch(function() {
          var tempEl = document.getElementById('ph-weather-temp');
          if (tempEl) tempEl.textContent = 'n/a';
        });
    }

    fetchWeather();
    // alle 15 Minuten aktualisieren
    setInterval(fetchWeather, 15 * 60 * 1000);
  }

  // Lokale Uhrzeit — live aktualisiert
  function initClock() {
    var el = document.getElementById('ph-locinfo');
    var timeEl = document.getElementById('ph-li-time');
    if (!el || !timeEl) return;
    var tz = el.getAttribute('data-tz') || 'Europe/Berlin';
    var fmt = new Intl.DateTimeFormat('de-DE', {
      hour: '2-digit', minute: '2-digit', second: '2-digit',
      timeZone: tz, hour12: false
    });
    function tick() { timeEl.textContent = fmt.format(new Date()); }
    tick();
    setInterval(tick, 1000);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () { initTimeline(); initClock(); initWeather(); initExchangeRate(); });
  } else {
    initTimeline();
    initClock();
    initWeather();
    initExchangeRate();
  }
})();
</script>

<!-- ═══════════════════════════════════════════════════════
     LOGBUCH — Letzte Einträge
═══════════════════════════════════════════════════════ -->

<!-- ═══════════════════════════════════════════════════════
     INSTAGRAM
═══════════════════════════════════════════════════════ -->
<section class="ph-ig reveal">
  <div class="ph-wrap" style="display:flex;align-items:center;gap:1.25rem;flex-wrap:wrap;">
    <div class="ph-ig-icon">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
    </div>
    <div style="flex:1;">
      <strong style="font-size:1rem;font-weight:700;color:#0F172A;display:block;">Auf Instagram mitverfolgen</strong>
      <p style="font-size:.875rem;color:#64748B;margin-top:2px;">Fotos, Stories, Updates in Echtzeit — @trepper</p>
    </div>
    <a href="https://instagram.com/trepper" target="_blank" rel="noopener" class="ph-ig-btn">Zum Profil</a>
  </div>
</section>

</div><!-- /.pg-home -->
</Layout>

<style is:global>
/* ────────────────────────────────────────────────────────
   TREPPER GLOBAL — Home (ph- Prefix, kein Bleeding)
──────────────────────────────────────────────────────── */

/* ── HERO ── */
.ph-hero {
  position: relative;
  overflow: hidden;
  background: #ffffff;
  padding: 3rem 1.5rem 2.5rem;
  border-bottom: 1px solid #E2E8F0;
  min-height: calc(100vh - 64px);
  display: flex;
  align-items: center;
}

.ph-blob { position:absolute; border-radius:50%; filter:blur(80px); pointer-events:none; z-index:0; }
.ph-b1 { width:480px; height:480px; background:#FFE0CC; top:-160px; right:-60px; opacity:.8; }
.ph-b2 { width:320px; height:320px; background:#C5EEFF; bottom:-60px; right:42%; opacity:.65; }
.ph-b3 { width:260px; height:260px; background:#FEF0C0; bottom:-40px; left:-60px; opacity:.55; }

.ph-hero-inner {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 420px 1fr;
  gap: 2.5rem;
  align-items: center;
}

/* ── HERO LEFT ── */
.ph-hero-left {
  display: flex;
  flex-direction: column;
  gap: 1.4rem;
}

/* ── LOC-INFO STRIP ── */
.ph-locinfo {
